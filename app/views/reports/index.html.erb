<p id="notice"><%= notice %></p>

<h1>Reports</h1>

<table class="table table-sm table-striped table-bordered table-hover">
  <thead class="thead-dark">
    <tr>
      <th>Report</th>
      <!-- <th>String</th> -->
      <th>Name</th>
      <th>Description</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @reports.each do |report| %>
      <tr>
        <td><%= report.report %></td>
        <!-- <td><%= report.string %></td> -->
        <td><%= report.name %></td>
        <td><%= report.description %></td>
        <td><%= link_to (render 'renders/button_show'), report, class:"btn btn-info btn-sm" %></td>
        <td><%= link_to (render 'renders/button_edit'), edit_report_path(report), class:"btn btn-primary btn-sm" %></td>
        <td><%= link_to (render 'renders/button_delete'), report, method: :delete, data: { confirm: 'Are you sure?' }, class:"btn btn-danger btn-sm" %></td>
      </tr>
    <% end %>
  </tbody>
</table>
<%= link_to 'New Report', new_report_path, class:"btn btn-primary btn-sm" %>
